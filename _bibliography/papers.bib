@inproceedings{robomind2025,
  abbr      = {RSS},
  title     = {RoboMIND: Benchmark on Multi-embodiment Intelligence Normative Data for Robot Manipulation},
  author    = {Qian, Siyuan and others},
  booktitle = {Robotics: Science and Systems (RSS)},
  year      = {2025},
  selected  = {true},
  bibtex_show = {true},
  abstract  = {We propose RoboMIND, a multi-embodiment robot teleoperation dataset covering 107K demonstration trajectories, 479 tasks, 96 object categories, and 4 robot morphologies, including failure cases and digital twin environments. Experiments verify that it significantly improves VLA model success rates and generalization capabilities, making it one of the largest and highest-quality datasets of its kind.}
}

@article{qian2024cot,
  abbr      = {VLM},
  title     = {Chain of Thought Prompt Tuning in Vision Language Models},
  author    = {Qian, Siyuan and others},
  year      = {2024},
  bibtex_show = {true},
  abstract  = {We propose a Chain-of-Thought prompt tuning method that introduces CoT into vision-language models by jointly leveraging visual and textual embedding information. This significantly improves generalization and transfer in image classification tasks, and demonstrates stronger reasoning performance in image-text retrieval and visual question answering tasks, achieving the first successful application of this method in visual tasks.}
}

@article{qian2023inr,
  abbr      = {Nat. Comput. Sci.},
  title     = {Implicit Neural Image Field for Biological Microscopy Image Compression},
  author    = {Qian, Siyuan and others},
  journal   = {Nature Computational Science},
  year      = {2023},
  selected  = {true},
  bibtex_show = {true},
  abstract  = {We propose an adaptive compression pipeline based on implicit neural representations (INR) that supports arbitrary-shape images and pixel-level decompression. It achieves controllable high compression ratios (up to 512x) and demonstrates effectiveness on various real biological microscopy images, significantly reducing storage and sharing burden while preserving critical analytical information.}
}
